# Line ending policy (Windows-target repo, Linux-based AI/CI tools)
# Default: treat as text and keep platform policy explicit per type.
* text=auto

# Windows text files -> CRLF
*.md          text eol=crlf
*.ps1         text eol=crlf
*.cmd         text eol=crlf
*.bat         text eol=crlf
*.cs          text eol=crlf
*.csproj      text eol=crlf
*.sln         text eol=crlf
*.props       text eol=crlf
*.targets     text eol=crlf
*.au3         text eol=crlf
*.json        text eol=crlf
*.xml         text eol=crlf
*.yml         text eol=crlf
*.yaml        text eol=crlf
*.txt         text eol=crlf
docs/task-scheduler/*.xml -text binary

# GitHub Actions workflows run on Linux -> LF
.github/workflows/**/*.yml  text eol=lf
.github/workflows/**/*.yaml text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.7z   binary
*.pdf  binary
*.exe  binary
*.dll  binary
*.pdb  binary
*.svg  binary
### BEGIN TEMPLATE-MANAGED-GITATTRIBUTES (DO NOT EDIT)
*.suo binary
*.user binary
### END TEMPLATE-MANAGED-GITATTRIBUTES
